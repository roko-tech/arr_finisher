# arr_finisher configuration — copy to `.env` and fill in your own keys.

# --- *arr services ---
RADARR_API_URL=http://localhost:7878
RADARR_API_KEY=

SONARR_API_URL=http://localhost:8989
SONARR_API_KEY=

# --- Rating providers ---
# https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# Unofficial MyDramaList API (kuryana). Leave default unless self-hosting.
KURYANA_BASE_URL=https://kuryana.tbdh.app

# Unofficial MyAnimeList API (jikan). Leave default unless self-hosting.
JIKAN_BASE_URL=https://api.jikan.moe/v4

# Primary language for Twitter hashtag searches and OpenSubtitles listings.
SEARCH_LANGUAGE=ar

# --- Subtitle providers ---
# https://subdl.com/panel/api
SUBDL_API_KEY=

# https://www.opensubtitles.com/en/consumers
OPENSUBTITLES_API_KEY=

# --- External tools ---
FOLDER_ICON_EXE=D:\Tools\FolderIconCreator\Creator.exe
